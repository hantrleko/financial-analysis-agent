ZHIPU_API_KEY=your_zhipu_glm_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Gemini model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Gemini thinking budget (-1 = dynamic/auto, 0 = off, 128-24576 for Flash, 128-32768 for Pro)
# GEMINI_THINKING_BUDGET=-1

# Optional: HTTP proxy for Gemini API (required in China mainland)
# GEMINI_PROXY=http://127.0.0.1:7890

# Optional: Access password for Streamlit web UI
# ACCESS_PASSWORD=
